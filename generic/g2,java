package generic;

interface Printer {
    <G, E> void pr(G a, E b);
}

class Sumy implements Printer {
    public <G, E> void pr(G a, E b) {
        System.out.println(a + " " + b);
    }
}

public class g1 {
    public static void main(String[] args) {
        Sumy obj = new Sumy();

        obj.pr(2, 2);
        obj.pr('c', 4);
    }
}